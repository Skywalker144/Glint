{
  "name": "glint",
  "version": "0.2.13",
  "private": true,
  "description": "闪译 · Glint — 划词 / 截图 / 输入翻译，黑白极简的跨平台桌面翻译工具（Electron）",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "postinstall": "node scripts/copy-vendor.js",
    "build:icon": "electron scripts/make-icon.js",
    "build:macocr": "bash scripts/build-macocr.sh",
    "dist:mac": "npm run build:macocr && electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "author": "Steve Tu",
  "license": "MIT",
  "homepage": "https://github.com/Skywalker144/Glint",
  "repository": {
    "type": "git",
    "url": "https://github.com/Skywalker144/Glint.git"
  },
  "build": {
    "appId": "com.skywalker144.glint",
    "productName": "Glint",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Skywalker144",
      "repo": "Glint"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      },
      "extraResources": [
        {
          "from": "resources/macocr",
          "to": "macocr"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-texmath": "^1.0.0",
    "tesseract.js": "^7.0.0"
  }
}
